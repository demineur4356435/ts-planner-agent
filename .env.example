# OpenAI (default when OLLAMA_BASE_URL is unset)
OPENAI_API_KEY=sk-...

# Optional: Anthropic — used when model id starts with anthropic/
ANTHROPIC_API_KEY=

# Optional: Groq OpenAI-compatible endpoint
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local Ollama (OpenAI-compatible API). When set, keys above are not required for local models.
# OLLAMA_BASE_URL=http://localhost:11434

# Default model (OpenAI name, or ollama model name when using Ollama)
PLANNER_MODEL=gpt-4o-mini

# REST API (npm run dev / npm start)
PORT=3000
