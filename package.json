{
  "name": "ts-planner-agent",
  "version": "1.0.0",
  "description": "Step-by-step task planning TypeScript AI agent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "cli": "node ./node_modules/tsx/dist/cli.mjs src/cli/index.ts",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:planning": "node ./node_modules/vitest/vitest.mjs run tests/planning.test.ts",
    "test:adaptation": "node ./node_modules/vitest/vitest.mjs run tests/adaptation.test.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "planner",
    "typescript",
    "vercel-ai-sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "ai": "^5.0.179",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
